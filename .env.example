# Milagram — environment variables
# Copy: cp .env.example .env
# Do not commit .env to git — it contains passwords!

# --- Required ---

# Admin user password (min. 4 characters)
ADMIN_PASSWORD=changeme

# Secret for JWT tokens. Without it, tokens are reset
# on every restart and all users are logged out.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# --- Optional ---

# Initial admin username (default: owner)
ADMIN_USERNAME=owner

# Data storage directory
# Local: ./posts | Docker: /data/posts (do not change)
DATA_DIR=./posts

# Path to the built frontend
# Local: ./frontend/dist | Docker: /app/frontend (do not change)
FRONTEND_PATH=./frontend/dist

# Allow self-registration (true/false)
ALLOW_REGISTRATION=false

# JWT token lifetime in days
JWT_EXPIRY_DAYS=365

# Allowed CORS origins (comma-separated)
# For production: https://milagram.example.com
# Default: * (all origins — unsafe for the internet)
# CORS_ORIGINS=https://milagram.example.com
